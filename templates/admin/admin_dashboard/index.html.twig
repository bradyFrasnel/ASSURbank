{% extends 'base.html.twig' %}

{% block title %}Administration — ASSURbank{% endblock %}

{% block body %}
<div class="container py-4">
    <div class="page-header d-flex justify-content-between align-items-center flex-wrap gap-2">
        <div>
            <h1 class="h3 fw-bold mb-1">Console d'administration</h1>
            <p class="text-muted mb-0">Supervision globale de la plateforme</p>
        </div>
        <span class="badge bg-danger">Administrateur</span>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-6 col-lg-3">
            <div class="dashboard-stat card text-center p-3">
                <p class="text-muted small mb-1">Banques partenaires</p>
                <h3 class="text-primary mb-0">{{ totalBanques }}</h3>
            </div>
        </div>
        <div class="col-md-6 col-lg-3">
            <div class="dashboard-stat card text-center p-3">
                <p class="text-muted small mb-1">Banques actives</p>
                <h3 class="text-success mb-0">{{ banquesActives }}</h3>
            </div>
        </div>
        <div class="col-md-6 col-lg-3">
            <div class="dashboard-stat card text-center p-3">
                <p class="text-muted small mb-1">Clients total</p>
                <h3 class="text-info mb-0">{{ totalClients }}</h3>
            </div>
        </div>
        <div class="col-md-6 col-lg-3">
            <div class="dashboard-stat card text-center p-3">
                <p class="text-muted small mb-1">Volume transactions</p>
                <h3 class="text-warning mb-0 fs-5">{{ volumeTransactions|number_format(0, ',', ' ') }} FCFA</h3>
                <small class="text-muted">{{ totalTransactions }} opération(s)</small>
            </div>
        </div>
    </div>

    <div class="table-card card">
        <div class="card-header bg-white py-3">
            <h5 class="mb-0 fw-bold">Banques enregistrées</h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">ID</th>
                            <th>Établissement</th>
                            <th>Email</th>
                            <th>Téléphone</th>
                            <th>Statut</th>
                            <th class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for banque in banques %}
                            <tr>
                                <td class="ps-4">#{{ banque.id }}</td>
                                <td class="fw-semibold">{{ banque.nom }}</td>
                                <td>{{ banque.email }}</td>
                                <td>{{ banque.telephone }}</td>
                                <td>
                                    <span class="badge badge-statut-{{ banque.statut }}">{{ banque.statut }}</span>
                                </td>
                                <td class="text-end pe-4">
                                    {% if banque.statut == 'actif' %}
                                        <form method="post" action="{{ path('app_admin_banque_desactiver', {id: banque.id}) }}" class="d-inline">
                                            <input type="hidden" name="_csrf_token" value="{{ csrf_token('submit') }}">
                                            <button type="submit" class="btn btn-sm btn-outline-danger"
                                                    onclick="return confirm('Désactiver cette banque ?')">
                                                Désactiver
                                            </button>
                                        </form>
                                    {% else %}
                                        <form method="post" action="{{ path('app_admin_banque_activer', {id: banque.id}) }}" class="d-inline">
                                            <input type="hidden" name="_csrf_token" value="{{ csrf_token('submit') }}">
                                            <button type="submit" class="btn btn-sm btn-outline-success">Activer</button>
                                        </form>
                                    {% endif %}
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="6" class="text-center py-5 text-muted">Aucune banque enregistrée.</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    {% include 'components/pagination.html.twig' with {
        pagination: pagination,
        route: 'app_admin_dashboard',
        query_params: {}
    } %}
</div>
{% endblock %}
