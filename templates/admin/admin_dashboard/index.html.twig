{% extends 'base.html.twig' %}

{% block title %}Espace Administration - ASSURbank{% endblock %}

{% block body %}
<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
        <h1 class="h2 text-dark">Console d'Administration Globale 🛡️</h1>
        <div>
            <span class="badge bg-secondary me-3">Mode: Administrateur</span>
            <a href="{{ path('app_logout') }}" class="btn btn-outline-danger btn-sm">Déconnexion</a>
        </div>
    </div>

    <div class="row mb-5">
        <div class="col-md-6 col-lg-4 mb-3">
            <div class="card border-primary h-100 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title text-muted text-uppercase small font-weight-bold">Total Banques Partenaires</h5>
                    <p class="display-5 text-primary font-weight-bold mb-0">{{ totalBanques }}</p>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-lg-4 mb-3">
            <div class="card border-success h-100 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title text-muted text-uppercase small font-weight-bold">Banques Actives</h5>
                    <p class="display-5 text-success font-weight-bold mb-0">{{ banquesActives }}</p>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center py-3">
            <h5 class="mb-0 fs-6 font-weight-bold">Banques enregistrées sur la plateforme</h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover table-striped align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">ID</th>
                            <th>Nom de l'établissement</th>
                            <th>Email de contact</th>
                            <th>Téléphone</th>
                            <th>Statut du compte</th>
                            <th class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for banque in banques %}
                            <tr>
                                <td class="ps-4"><strong>#{{ banque.id }}</strong></td>
                                <td>
                                    <span class="fw-bold text-dark">{{ banque.nom }}</span>
                                </td>
                                <td>{{ banque.email }}</td>
                                <td>{{ banque.telephone }}</td>
                                <td>
                                    {% if banque.statut == 'actif' %}
                                        <span class="badge bg-light-success text-success border border-success px-2.5 py-1">Actif</span>
                                    {% else %}
                                        <span class="badge bg-light-danger text-danger border border-danger px-2.5 py-1">Inactif</span>
                                    {% endif %}
                                </td>
                                <td class="text-end pe-4">
                                    <button class="btn btn-sm btn-outline-secondary me-1">Gérer</button>
                                    <button class="btn btn-sm btn-light text-danger">Suspendre</button>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="6" class="text-center py-5 text-muted">
                                    <i class="fs-3 d-block mb-2">🏦</i>
                                    Aucune institution bancaire n'est enregistrée pour le moment.
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    /* Styles utilitaires légers en attendant la liaison complète des assets */
    .bg-light-success { background-color: #e8f5e9 !important; }
    .bg-light-danger { background-color: #ffebee !important; }
</style>
{% endblock %}