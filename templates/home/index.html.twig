{% extends 'base.html.twig' %}

{% block title %}ASSURbank — Banque en ligne{% endblock %}

{% block body %}
<section class="hero-section text-center">
    <div class="container">
        <h1 class="hero-title mb-3">Bienvenue sur <span class="hero-accent">ASSURbank</span></h1>
        <p class="lead mb-0 opacity-90">Votre plateforme bancaire multi-banques — simple, sécurisée et accessible</p>
    </div>
</section>

<section class="portal-section pb-5">
    <div class="container">
        <div class="text-center mb-4">
            <h2 class="fw-bold">Choisissez votre espace</h2>
            <p class="text-muted">Connectez-vous ou créez un compte selon votre profil</p>
        </div>

        <div class="row g-4 justify-content-center">
            {# Espace Client #}
            <div class="col-md-6 col-lg-4">
                <div class="card portal-card h-100">
                    <div class="card-header-bar bg-primary"></div>
                    <div class="card-body text-center p-4">
                        <div class="portal-icon portal-icon-client">
                            <i class="bi bi-person-circle"></i>
                        </div>
                        <h4 class="fw-bold">Espace Client</h4>
                        <p class="text-muted small">Consultez vos comptes, effectuez des virements et suivez vos transactions.</p>
                        <a href="{{ path('app_login_client') }}" class="btn btn-primary btn-portal w-100 mb-2">
                            <i class="bi bi-box-arrow-in-right me-1"></i> Se connecter
                        </a>
                        <a href="{{ path('app_client_inscription') }}" class="btn btn-outline-primary btn-portal w-100">
                            <i class="bi bi-person-plus me-1"></i> Créer un compte
                        </a>
                    </div>
                </div>
            </div>

            {# Espace Banque #}
            <div class="col-md-6 col-lg-4">
                <div class="card portal-card h-100">
                    <div class="card-header-bar bg-success"></div>
                    <div class="card-body text-center p-4">
                        <div class="portal-icon portal-icon-banque">
                            <i class="bi bi-bank"></i>
                        </div>
                        <h4 class="fw-bold">Espace Banque</h4>
                        <p class="text-muted small">Gérez vos clients, créez des comptes et supervisez les opérations.</p>
                        <a href="{{ path('app_login_banque') }}" class="btn btn-success btn-portal w-100 mb-2">
                            <i class="bi bi-box-arrow-in-right me-1"></i> Se connecter
                        </a>
                        <a href="{{ path('app_banque_inscription') }}" class="btn btn-outline-success btn-portal w-100">
                            <i class="bi bi-building-add me-1"></i> Inscrire ma banque
                        </a>
                    </div>
                </div>
            </div>

            {# Espace Admin #}
            <div class="col-md-6 col-lg-4">
                <div class="card portal-card h-100">
                    <div class="card-header-bar bg-danger"></div>
                    <div class="card-body text-center p-4">
                        <div class="portal-icon portal-icon-admin">
                            <i class="bi bi-shield-lock"></i>
                        </div>
                        <h4 class="fw-bold">Administration</h4>
                        <p class="text-muted small">Supervision globale de la plateforme et des banques partenaires.</p>
                        <a href="{{ path('app_login_admin') }}" class="btn btn-danger btn-portal w-100 mb-2">
                            <i class="bi bi-box-arrow-in-right me-1"></i> Se connecter
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-5 bg-white">
    <div class="container">
        <div class="row g-4">
            <div class="col-md-4">
                <div class="card feature-card p-3">
                    <div class="card-body text-center">
                        <i class="bi bi-shield-check feature-icon mb-3 d-block"></i>
                        <h5 class="fw-bold">Sécurité maximale</h5>
                        <p class="text-muted small mb-0">Authentification sécurisée, chiffrement Argon2 et protection CSRF.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card feature-card p-3">
                    <div class="card-body text-center">
                        <i class="bi bi-lightning-charge feature-icon mb-3 d-block"></i>
                        <h5 class="fw-bold">Virements internes</h5>
                        <p class="text-muted small mb-0">Transférez des fonds entre vos comptes en toute simplicité.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card feature-card p-3">
                    <div class="card-body text-center">
                        <i class="bi bi-graph-up-arrow feature-icon mb-3 d-block"></i>
                        <h5 class="fw-bold">Suivi en temps réel</h5>
                        <p class="text-muted small mb-0">Historique complet de vos transactions et soldes actualisés.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}
