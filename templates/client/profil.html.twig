{% extends 'base.html.twig' %}

{% block title %}Mon Profil{% endblock %}

{% block body %}
<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="page-header">
                <h1 class="h3 fw-bold mb-1">Mon Profil</h1>
            </div>

            <div class="auth-card card mb-4">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-3">Informations</h5>
                    <dl class="row mb-0">
                        <dt class="col-sm-4 text-muted">Nom</dt><dd class="col-sm-8">{{ client.nom }}</dd>
                        <dt class="col-sm-4 text-muted">Prénom</dt><dd class="col-sm-8">{{ client.prenom }}</dd>
                        <dt class="col-sm-4 text-muted">Email</dt><dd class="col-sm-8">{{ client.email }}</dd>
                        <dt class="col-sm-4 text-muted">Téléphone</dt><dd class="col-sm-8">{{ client.telephone }}</dd>
                        <dt class="col-sm-4 text-muted">Banque</dt><dd class="col-sm-8">{{ client.banque ? client.banque.nom : '—' }}</dd>
                        <dt class="col-sm-4 text-muted">Statut</dt>
                        <dd class="col-sm-8"><span class="badge badge-statut-{{ client.statut }}">{{ client.statut }}</span></dd>
                    </dl>
                </div>
            </div>

            <div class="auth-card card">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-3">Modifier le mot de passe</h5>
                    {{ form_start(form) }}
                        {{ form_row(form.plainPassword) }}
                        <button type="submit" class="btn btn-primary btn-portal">
                            <i class="bi bi-key me-1"></i> Mettre à jour
                        </button>
                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
