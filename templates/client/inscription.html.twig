{% extends 'base.html.twig' %}

{% block title %}Inscription Client{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-7 col-lg-6">
            <div class="auth-card card">
                <div class="auth-card-header primary">
                    <i class="bi bi-person-plus auth-icon"></i>
                    <h3 class="mb-1">Inscription Client</h3>
                    <p class="mb-0 opacity-75 small">Créez votre compte et choisissez votre banque</p>
                </div>
                <div class="card-body p-4">
                    {% if banques is empty %}
                        <div class="alert alert-warning">
                            Aucune banque active disponible pour le moment.
                        </div>
                    {% else %}
                        {{ form_start(form) }}
                            {{ form_row(form.nom) }}
                            {{ form_row(form.prenom) }}
                            {{ form_row(form.email) }}
                            {{ form_row(form.telephone) }}
                            {{ form_row(form.plainPassword) }}
                            {{ form_row(form.banque) }}
                            <button type="submit" class="btn btn-primary btn-portal w-100 py-2 mt-2">
                                <i class="bi bi-check-circle me-1"></i> S'inscrire
                            </button>
                        {{ form_end(form) }}
                    {% endif %}

                    <hr class="my-3">
                    <a href="{{ path('app_login_client') }}" class="btn btn-outline-primary w-100 btn-portal">Se connecter</a>
                </div>
            </div>
            <div class="text-center mt-3">
                <a href="{{ path('app_home') }}" class="text-muted small text-decoration-none">
                    <i class="bi bi-arrow-left me-1"></i> Retour à l'accueil
                </a>
            </div>
        </div>
    </div>
</div>
{% endblock %}
