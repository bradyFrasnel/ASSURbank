{% extends 'base.html.twig' %}

{% block title %}Dashboard Client{% endblock %}

{% block body %}
<div class="container py-4">
    <div class="page-header">
        <h1 class="h3 fw-bold mb-1">Bonjour, {{ client.prenom }} {{ client.nom }}</h1>
        <p class="text-muted mb-0">
            <i class="bi bi-bank me-1"></i>{{ client.banque ? client.banque.nom : 'Banque non assignée' }}
        </p>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-3 col-6">
            <div class="dashboard-stat card text-center p-3">
                <p class="text-muted small mb-1">Comptes</p>
                <h3 class="text-primary mb-0">{{ totalComptes }}</h3>
            </div>
        </div>
        <div class="col-md-3 col-6">
            <div class="dashboard-stat card text-center p-3">
                <p class="text-muted small mb-1">Solde total</p>
                <h3 class="text-success mb-0 fs-5">{{ soldeTotal|number_format(2, ',', ' ') }} FCFA</h3>
            </div>
        </div>
        <div class="col-md-3 col-6">
            <div class="dashboard-stat card text-center p-3">
                <p class="text-muted small mb-1">Transactions</p>
                <h3 class="text-info mb-0">{{ totalTransactions }}</h3>
            </div>
        </div>
        <div class="col-md-3 col-6">
            <div class="dashboard-stat card text-center p-3">
                <p class="text-muted small mb-1">Statut</p>
                <span class="badge badge-statut-{{ client.statut }} fs-6">{{ client.statut }}</span>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h6 class="card-title fw-bold mb-3">Crédits vs Débits</h6>
                    <div class="chart-container" style="position: relative; height: 300px;">
                        <canvas id="creditDebitChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h6 class="card-title fw-bold mb-3">Statistiques des comptes</h6>
                    <div class="text-center py-4">
                        <div class="display-6 text-success mb-2">{{ comptesActifs }} / {{ totalComptes }}</div>
                        <p class="text-muted mb-0">Comptes actifs</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-6">
            <div class="table-card card shadow-sm">
                <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">
                    <h5 class="mb-0 fw-bold">Mes Comptes</h5>
                    <a href="{{ path('app_client_comptes') }}" class="btn btn-sm btn-outline-primary">Voir tout</a>
                </div>
                <div class="card-body p-0">
                    {% if comptes is empty %}
                        <div class="text-center py-4 text-muted">Aucun compte disponible.</div>
                    {% else %}
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th class="ps-4">Numéro</th>
                                        <th>Type</th>
                                        <th>Solde</th>
                                        <th class="pe-4">Statut</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for compte in comptes %}
                                        <tr>
                                            <td class="ps-4"><code class="small">{{ compte.numeroCompte|slice(0, 12) }}…</code></td>
                                            <td class="text-capitalize">{{ compte.type }}</td>
                                            <td class="fw-semibold">{{ compte.solde|number_format(2, ',', ' ') }} FCFA</td>
                                            <td class="pe-4">
                                                <span class="badge badge-statut-{{ compte.statut }}">{{ compte.statut }}</span>
                                            </td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="table-card card shadow-sm">
                <div class="card-header bg-white py-3">
                    <h5 class="mb-0 fw-bold">Dernières Transactions</h5>
                </div>
                <div class="card-body p-0">
                    {% if transactions is empty %}
                        <div class="text-center py-4 text-muted">Aucune transaction récente.</div>
                    {% else %}
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th class="ps-4">Date</th>
                                        <th>Type</th>
                                        <th>Montant</th>
                                        <th class="pe-4">Statut</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for transaction in transactions %}
                                        <tr>
                                            <td class="ps-4 small">{{ transaction.dateTransaction|date('d/m/Y H:i') }}</td>
                                            <td>
                                                <span class="badge bg-{{ transaction.type == 'crédit' ? 'success' : 'danger' }}">
                                                    {{ transaction.type }}
                                                </span>
                                            </td>
                                            <td class="fw-semibold">{{ transaction.montant|number_format(2, ',', ' ') }}</td>
                                            <td class="pe-4">
                                                <span class="badge bg-{{ transaction.statut == 'succès' ? 'success' : 'danger' }}">
                                                    {{ transaction.statut }}
                                                </span>
                                            </td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>

    <div class="mt-4 d-flex flex-wrap gap-2">
        <a href="{{ path('app_client_comptes') }}" class="btn btn-primary btn-portal">
            <i class="bi bi-wallet2 me-1"></i> Mes comptes
        </a>
        <a href="{{ path('app_client_virement') }}" class="btn btn-success btn-portal">
            <i class="bi bi-arrow-left-right me-1"></i> Effectuer un virement
        </a>
        <a href="{{ path('app_client_transactions') }}" class="btn btn-outline-primary btn-portal">
            <i class="bi bi-clock-history me-1"></i> Historique
        </a>
        <a href="{{ path('app_client_profil') }}" class="btn btn-outline-secondary btn-portal">
            <i class="bi bi-person me-1"></i> Mon profil
        </a>
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    document.addEventListener('DOMContentLoaded', function() {
        new Chart(document.getElementById('creditDebitChart'), {
            type: 'doughnut',
            data: {
                labels: ['Crédits', 'Débits'],
                datasets: [{
                    data: [{{ totalCredit }}, {{ totalDebit }}],
                    backgroundColor: ['#10b981', '#ef4444'],
                    borderWidth: 4,
                    borderColor: '#ffffff'
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                cutout: '65%',
                plugins: {
                    legend: {
                        position: 'bottom',
                        labels: {
                            padding: 20,
                            font: {
                                size: 14
                            }
                        }
                    },
                    tooltip: {
                        backgroundColor: 'rgba(0, 0, 0, 0.8)',
                        padding: 12,
                        titleFont: {
                            size: 14
                        },
                        bodyFont: {
                            size: 13
                        }
                    }
                },
                animation: {
                    animateRotate: true,
                    animateScale: true,
                    duration: 1200
                }
            }
        });
    });
</script>
{% endblock %}
