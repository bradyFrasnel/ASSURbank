{% extends 'base.html.twig' %}

{% block title %}Virement{% endblock %}

{% block body %}
<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="page-header text-center">
                <h1 class="h3 fw-bold">Effectuer un virement</h1>
            </div>

            <div class="auth-card card">
                <div class="card-body p-4">
                    {% if error %}
                        <div class="alert alert-danger"><i class="bi bi-exclamation-triangle me-1"></i>{{ error }}</div>
                    {% endif %}
                    {% if success %}
                        <div class="alert alert-success"><i class="bi bi-check-circle me-1"></i>{{ success }}</div>
                    {% endif %}

                    {% if comptes is empty %}
                        <div class="alert alert-warning">Aucun compte actif disponible.</div>
                        <a href="{{ path('app_client_dashboard') }}" class="btn btn-primary">Retour</a>
                    {% else %}
                        {{ form_start(form) }}
                            {{ form_row(form.compteSource) }}
                            {{ form_row(form.compteDestination) }}
                            {{ form_row(form.montant) }}
                            {{ form_row(form.libelle) }}
                            <button type="submit" class="btn btn-success btn-portal w-100 py-2">
                                <i class="bi bi-arrow-left-right me-1"></i> Effectuer le virement
                            </button>
                        {{ form_end(form) }}
                        <div class="text-center mt-3">
                            <a href="{{ path('app_client_dashboard') }}" class="btn btn-outline-secondary btn-sm">Annuler</a>
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
