{% extends 'base.html.twig' %}

{% block title %}Dashboard Banque{% endblock %}

{% block body %}
<div class="container py-4">
    <div class="page-header">
        <h1 class="h3 fw-bold mb-1">{{ banque.nom }}</h1>
        <p class="text-muted mb-0">{{ banque.email }}</p>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-3 col-6">
            <div class="dashboard-stat card text-center p-3">
                <p class="text-muted small mb-1">Clients</p>
                <h3 class="text-primary mb-0">{{ totalClients }}</h3>
            </div>
        </div>
        <div class="col-md-3 col-6">
            <div class="dashboard-stat card text-center p-3">
                <p class="text-muted small mb-1">Comptes</p>
                <h3 class="text-success mb-0">{{ totalComptes }}</h3>
            </div>
        </div>
        <div class="col-md-3 col-6">
            <div class="dashboard-stat card text-center p-3">
                <p class="text-muted small mb-1">Montant géré</p>
                <h3 class="text-info mb-0 fs-5">{{ montantTotal|number_format(0, ',', ' ') }} FCFA</h3>
            </div>
        </div>
        <div class="col-md-3 col-6">
            <div class="dashboard-stat card text-center p-3">
                <p class="text-muted small mb-1">Transactions</p>
                <h3 class="text-warning mb-0">{{ totalTransactions }}</h3>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h6 class="card-title fw-bold mb-3">Répartition des clients</h6>
                    <div class="chart-container" style="position: relative; height: 300px;">
                        <canvas id="clientsChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h6 class="card-title fw-bold mb-3">Répartition des comptes</h6>
                    <div class="chart-container" style="position: relative; height: 300px;">
                        <canvas id="comptesChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="table-card card shadow-sm">
        <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">
            <h5 class="mb-0 fw-bold">Clients récents</h5>
            <a href="{{ path('app_banque_clients') }}" class="btn btn-sm btn-outline-primary">Tous les clients</a>
        </div>
        <div class="card-body p-0">
            {% if clients is empty %}
                <div class="text-center py-4 text-muted">Aucun client enregistré.</div>
            {% else %}
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-4">Nom</th>
                                <th>Email</th>
                                <th>Statut</th>
                                <th class="text-end pe-4">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for client in clients|slice(0, 5) %}
                                <tr>
                                    <td class="ps-4 fw-semibold">{{ client.prenom }} {{ client.nom }}</td>
                                    <td>{{ client.email }}</td>
                                    <td><span class="badge badge-statut-{{ client.statut }}">{{ client.statut }}</span></td>
                                    <td class="text-end pe-4">
                                        <a href="{{ path('app_banque_client_show', {id: client.id}) }}" class="btn btn-sm btn-outline-primary">Voir</a>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% endif %}
        </div>
    </div>

    <div class="mt-4 d-flex flex-wrap gap-2">
        <a href="{{ path('app_banque_clients') }}" class="btn btn-primary btn-portal">
            <i class="bi bi-people me-1"></i> Gérer les clients
        </a>
        <a href="{{ path('app_banque_compte_create') }}" class="btn btn-success btn-portal">
            <i class="bi bi-plus-circle me-1"></i> Créer un compte
        </a>
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    document.addEventListener('DOMContentLoaded', function() {
        // Chart clients
        new Chart(document.getElementById('clientsChart'), {
            type: 'doughnut',
            data: {
                labels: ['Actifs', 'Inactifs'],
                datasets: [{
                    data: [{{ clientsActifs }}, {{ clientsInactifs }}],
                    backgroundColor: ['#10b981', '#ef4444'],
                    borderWidth: 4,
                    borderColor: '#ffffff'
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                cutout: '65%',
                plugins: {
                    legend: {
                        position: 'bottom',
                        labels: {
                            padding: 20,
                            font: {
                                size: 14
                            }
                        }
                    },
                    tooltip: {
                        backgroundColor: 'rgba(0, 0, 0, 0.8)',
                        padding: 12,
                        titleFont: {
                            size: 14
                        },
                        bodyFont: {
                            size: 13
                        }
                    }
                },
                animation: {
                    animateRotate: true,
                    animateScale: true,
                    duration: 1200
                }
            }
        });

        // Chart comptes
        new Chart(document.getElementById('comptesChart'), {
            type: 'doughnut',
            data: {
                labels: ['Actifs', 'Inactifs'],
                datasets: [{
                    data: [{{ comptesActifs }}, {{ comptesInactifs }}],
                    backgroundColor: ['#059669', '#dc2626'],
                    borderWidth: 4,
                    borderColor: '#ffffff'
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                cutout: '65%',
                plugins: {
                    legend: {
                        position: 'bottom',
                        labels: {
                            padding: 20,
                            font: {
                                size: 14
                            }
                        }
                    },
                    tooltip: {
                        backgroundColor: 'rgba(0, 0, 0, 0.8)',
                        padding: 12,
                        titleFont: {
                            size: 14
                        },
                        bodyFont: {
                            size: 13
                        }
                    }
                },
                animation: {
                    animateRotate: true,
                    animateScale: true,
                    duration: 1200
                }
            }
        });
    });
</script>
{% endblock %}
