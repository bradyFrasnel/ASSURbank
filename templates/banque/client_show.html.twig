{% extends 'base.html.twig' %}

{% block title %}Client {{ client.prenom }} {{ client.nom }}{% endblock %}

{% block body %}
<div class="container py-4">
    <div class="page-header d-flex justify-content-between align-items-center flex-wrap gap-2">
        <div>
            <h1 class="h3 fw-bold mb-1">{{ client.prenom }} {{ client.nom }}</h1>
            <p class="text-muted mb-0">{{ client.email }}</p>
        </div>
        <a href="{{ path('app_banque_clients') }}" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i> Retour
        </a>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-md-6">
            <div class="auth-card card">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-3">Informations client</h5>
                    <dl class="row mb-0">
                        <dt class="col-sm-4 text-muted">Téléphone</dt>
                        <dd class="col-sm-8">{{ client.telephone }}</dd>
                        <dt class="col-sm-4 text-muted">Statut</dt>
                        <dd class="col-sm-8">
                            <span class="badge badge-statut-{{ client.statut }}">{{ client.statut }}</span>
                        </dd>
                        <dt class="col-sm-4 text-muted">Inscrit le</dt>
                        <dd class="col-sm-8">{{ client.dateCreation|date('d/m/Y') }}</dd>
                    </dl>
                    <div class="mt-3 d-flex gap-2">
                        {% if client.statut == 'actif' %}
                            <form method="post" action="{{ path('app_banque_client_desactiver', {id: client.id}) }}">
                                <input type="hidden" name="_csrf_token" value="{{ csrf_token('submit') }}">
                                <button type="submit" class="btn btn-sm btn-outline-danger">Désactiver le client</button>
                            </form>
                        {% else %}
                            <form method="post" action="{{ path('app_banque_client_activer', {id: client.id}) }}">
                                <input type="hidden" name="_csrf_token" value="{{ csrf_token('submit') }}">
                                <button type="submit" class="btn btn-sm btn-outline-success">Activer le client</button>
                            </form>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="dashboard-stat card p-4 text-center h-100 d-flex flex-column justify-content-center">
                <p class="text-muted mb-1">Comptes du client</p>
                <h2 class="text-primary mb-3">{{ comptes|length }}</h2>
                <a href="{{ path('app_banque_compte_create') }}?client_id={{ client.id }}" class="btn btn-success btn-sm">
                    <i class="bi bi-plus-circle me-1"></i> Créer un compte
                </a>
            </div>
        </div>
    </div>

    <div class="table-card card">
        <div class="card-header bg-white py-3">
            <h5 class="mb-0 fw-bold">Comptes bancaires</h5>
        </div>
        <div class="card-body p-0">
            {% if comptes is empty %}
                <div class="text-center py-4 text-muted">Aucun compte ouvert pour ce client.</div>
            {% else %}
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-4">Numéro</th>
                                <th>Type</th>
                                <th>Solde</th>
                                <th>Statut</th>
                                <th class="text-end pe-4">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for compte in comptes %}
                                <tr>
                                    <td class="ps-4"><code>{{ compte.numeroCompte }}</code></td>
                                    <td class="text-capitalize">{{ compte.type }}</td>
                                    <td class="fw-semibold">{{ compte.solde|number_format(2, ',', ' ') }} FCFA</td>
                                    <td>
                                        <span class="badge badge-statut-{{ compte.statut }}">{{ compte.statut }}</span>
                                    </td>
                                    <td class="text-end pe-4">
                                        {% if compte.statut == 'actif' %}
                                            <form method="post" action="{{ path('app_banque_compte_desactiver', {id: compte.id}) }}" class="d-inline">
                                                <input type="hidden" name="_csrf_token" value="{{ csrf_token('submit') }}">
                                                <button type="submit" class="btn btn-sm btn-outline-danger">Désactiver</button>
                                            </form>
                                        {% else %}
                                            <form method="post" action="{{ path('app_banque_compte_activer', {id: compte.id}) }}" class="d-inline">
                                                <input type="hidden" name="_csrf_token" value="{{ csrf_token('submit') }}">
                                                <button type="submit" class="btn btn-sm btn-outline-success">Activer</button>
                                            </form>
                                        {% endif %}
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
