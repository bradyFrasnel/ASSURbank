<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}ASSURbank{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🏦</text></svg>">
        {% block stylesheets %}
            <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
            <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
        {% endblock %}
        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
        {% endblock %}
        {% set frankenphpHotReload = app.request.server.get('FRANKENPHP_HOT_RELOAD') %}
        {% if frankenphpHotReload %}
        <meta name="frankenphp-hot-reload:url" content="{{ frankenphpHotReload }}">
        <script src="https://cdn.jsdelivr.net/npm/idiomorph"></script>
        <script src="https://cdn.jsdelivr.net/npm/frankenphp-hot-reload/+esm" type="module"></script>
        {% endif %}
    </head>
    <body>
        {% if is_granted('ROLE_ADMIN') %}
            {% set portal_route = 'app_admin_dashboard' %}
        {% elseif is_granted('ROLE_BANQUE') %}
            {% set portal_route = 'app_banque_dashboard' %}
        {% elseif is_granted('ROLE_CLIENT') %}
            {% set portal_route = 'app_client_dashboard' %}
        {% else %}
            {% set portal_route = 'app_home' %}
        {% endif %}

        <nav class="navbar navbar-expand-lg navbar-dark navbar-ab">
            <div class="container">
                <a class="navbar-brand" href="{{ path(portal_route) }}">
                    <i class="bi bi-bank2 me-1"></i> ASSURbank
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto">
                        {% if not app.user %}
                            <li class="nav-item">
                                <a class="nav-link" href="{{ path('app_home') }}">Accueil</a>
                            </li>
                        {% endif %}
                        {% if is_granted('ROLE_CLIENT') %}
                            <li class="nav-item"><a class="nav-link" href="{{ path('app_client_dashboard') }}">Mon espace</a></li>
                            <li class="nav-item"><a class="nav-link" href="{{ path('app_client_comptes') }}">Mes comptes</a></li>
                            <li class="nav-item"><a class="nav-link" href="{{ path('app_client_virement') }}">Virement</a></li>
                            <li class="nav-item"><a class="nav-link" href="{{ path('app_client_transactions') }}">Historique</a></li>
                        {% elseif is_granted('ROLE_BANQUE') %}
                            <li class="nav-item"><a class="nav-link" href="{{ path('app_banque_dashboard') }}">Dashboard</a></li>
                            <li class="nav-item"><a class="nav-link" href="{{ path('app_banque_clients') }}">Clients</a></li>
                        {% elseif is_granted('ROLE_ADMIN') %}
                            <li class="nav-item"><a class="nav-link" href="{{ path('app_admin_dashboard') }}">Administration</a></li>
                        {% endif %}
                    </ul>
                    <ul class="navbar-nav">
                        {% if app.user %}
                            <li class="nav-item">
                                <span class="nav-link text-white-50">
                                    <i class="bi bi-person-check me-1"></i>{{ app.user.userIdentifier }}
                                </span>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link btn btn-outline-light btn-sm ms-2 px-3" href="{{ path('app_logout') }}">Déconnexion</a>
                            </li>
                        {% else %}
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">Connexion</a>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    <li><a class="dropdown-item" href="{{ path('app_login_client') }}"><i class="bi bi-person me-2"></i>Espace Client</a></li>
                                    <li><a class="dropdown-item" href="{{ path('app_login_banque') }}"><i class="bi bi-bank me-2"></i>Espace Banque</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item" href="{{ path('app_login_admin') }}"><i class="bi bi-shield-lock me-2"></i>Administration</a></li>
                                </ul>
                            </li>
                        {% endif %}
                    </ul>
                </div>
            </div>
        </nav>

        <main>
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="container mt-3">
                        <div class="alert alert-{{ label == 'error' ? 'danger' : label }} alert-dismissible fade show" role="alert">
                            {{ message }}
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    </div>
                {% endfor %}
            {% endfor %}

            {% block body %}{% endblock %}
        </main>

        <footer class="footer-ab text-center">
            <div class="container">
                <p class="mb-0">&copy; {{ "now"|date("Y") }} ASSURbank — Plateforme bancaire sécurisée</p>
            </div>
        </footer>
    </body>
</html>
