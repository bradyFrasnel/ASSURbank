{% if pagination.totalPages > 1 %}
<nav aria-label="Pagination" class="mt-3">
    <ul class="pagination justify-content-center mb-0">
        <li class="page-item {{ pagination.hasPrevious ? '' : 'disabled' }}">
            <a class="page-link" href="{{ path(route, query_params|merge({page: pagination.page - 1})) }}">
                <i class="bi bi-chevron-left"></i>
            </a>
        </li>
        {% for p in 1..pagination.totalPages %}
            {% if p == 1 or p == pagination.totalPages or (p >= pagination.page - 2 and p <= pagination.page + 2) %}
                <li class="page-item {{ p == pagination.page ? 'active' : '' }}">
                    <a class="page-link" href="{{ path(route, query_params|merge({page: p})) }}">{{ p }}</a>
                </li>
            {% elseif p == pagination.page - 3 or p == pagination.page + 3 %}
                <li class="page-item disabled"><span class="page-link">…</span></li>
            {% endif %}
        {% endfor %}
        <li class="page-item {{ pagination.hasNext ? '' : 'disabled' }}">
            <a class="page-link" href="{{ path(route, query_params|merge({page: pagination.page + 1})) }}">
                <i class="bi bi-chevron-right"></i>
            </a>
        </li>
    </ul>
    <p class="text-center text-muted small mt-2">
        {{ pagination.total }} résultat(s) — page {{ pagination.page }}/{{ pagination.totalPages }}
    </p>
</nav>
{% endif %}
